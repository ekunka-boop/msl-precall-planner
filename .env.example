# Required for the engagement report (LLM generation at runtime).
# Get one at https://console.anthropic.com/
ANTHROPIC_API_KEY=

# Optional. Defaults to claude-sonnet-4-6.
ANTHROPIC_MODEL=claude-sonnet-4-6

# Optional. An NCBI API key raises PubMed rate limits from 3 to 10 req/sec.
# https://www.ncbi.nlm.nih.gov/account/settings/
NCBI_API_KEY=
